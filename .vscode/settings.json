{
  "go.formatTool": "gofumpt",
  "editor.formatOnSave": true,
  "[go]": {
    "editor.formatOnSave": true
  },
  "gopls": {
    "formatting.gofumpt": true
  },

  // Hide generated templ Go files since they're almost never interesting to
  // look at and just keep getting in the way.
  "files.exclude": {
    "**/*_templ.go": true
  },

  "files.associations": {
    "*.tw.css": "tailwindcss", // treat .tw.css as Tailwind CSS
  },
  "tailwindCSS.experimental.configFile": "./internal/webedit/style.tw.css",
  // Instruct IntelliSense to also scan .templ files for classes
  "tailwindCSS.includeLanguages": {
    "html": "html",        // default
    "templ": "html"
  },
  "markdown.extension.toc.levels": "2..6"
}
